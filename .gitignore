/third_party

# ── ML artifacts (industry-standard exclusions) ──────────────────────
# Weights, optimizer state, and EMA shadows. Never commit these — they
# live on the cluster scratch disk (see configs/diffab_ft/vhh_ft.yml's
# init_checkpoint comment for the canonical location on Snellius).
*.pt
*.pth
*.ckpt
*.safetensors

# Per-run outputs.
/runs/
/logs/
# Ignore generated parquets under /data/results/ by default, but keep the
# threshold-calibration parquets versioned so the AbDPO §E.1 percentile
# derivation reproduces without HPC access. (Negations on individual files
# only work if the parent directory itself is not ignored — hence the glob
# on contents rather than a directory-level ignore.)
/data/results/*
!/data/results/andd_calibration_pack.parquet
!/data/results/andd_calibration_full.parquet

# DiffAb's LMDB cache + MMseqs2 intermediates.
/data/processed/
/data/datasets/clustering/cluster_tmp/
/data/datasets/clustering/antigen_tmp/

# W&B local cache.
/wandb/
**/wandb/

# Python bytecode / venv.
__pycache__/
*.py[cod]
.venv/
venv/
/docs
