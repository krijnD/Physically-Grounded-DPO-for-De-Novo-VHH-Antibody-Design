#!/bin/bash
# Snellius SLURM script: VHH fine-tune on the J-anchor-fixed dataset.
#
# Background: forensic investigation (docs/aapr_masking_research_context.md,
# 2026-05-21 → 2026-05-22 session) discovered that DiffAb's PDB parser
# was silently capping the heavy chain at resseq=113. That cap is
# correct for Chothia-numbered antibody PDBs (Chothia 113 = last
# residue of WGQGTQVTVSS J-anchor), but our VHH PDBs come straight
# from RCSB and mostly use sequential or author numbering — for those
# the cap landed mid-CDR3 or right after the W of the J-anchor. Net
# effect: 22 of 29 test-split GTs (76%) lost the J-anchor at the
# dataset level. seed42_dedup was trained on this corrupted view.
#
# Fix: commit 5c4f966 ("GT data loader problem") — VHHANDDDataset
# now overrides _preprocess_structures with a configurable
# heavy_max_resseq (default 150). The LMDB at
# data/processed/vhh_ft/structures.lmdb must be rebuilt before this
# job runs (deleted + regenerated by check_gt_jregion.py or train.py
# on first iter); the rebuild itself takes ~30s.
#
# Comparison: seed42_dedup (truncated) vs seed42_jfix (full-anchor)
# is the headline ablation for the data-quality result in the thesis.
# Do not delete runs/vhh_ft/seed42_dedup/.
#
# Submit from the project root:
#     sbatch scripts/diffab_ft/slurm/train_seed42_jfix.sbatch
#
# Outputs:
#   logs/slurm/diffab_ft_jfix_<jobid>.out  — combined stdout/stderr.
#   runs/vhh_ft/seed42_jfix/               — per-run artifacts (configs,
#                                              checkpoints, log.txt).
#
# Wall time budget: ~12-18h on a single A100 for 20K iters with our
# settings; 24h leaves headroom for warm-up I/O.

#SBATCH --partition=gpu_a100
#SBATCH --gpus=1
#SBATCH --cpus-per-task=18
#SBATCH --mem=120G
#SBATCH --time=24:00:00
#SBATCH --job-name=diffab_ft_jfix
#SBATCH --output=logs/slurm/%x_%j.out

set -euo pipefail

# ── Modules + venv ──────────────────────────────────────────────────
module load 2024
module load Python/3.12.3-GCCcore-13.3.0
source /projects/0/hpmlprjs/interns/krijn/venvs/DPO/bin/activate

# Make sure logs/slurm exists (sbatch fails before the job script runs
# otherwise, but harmless on re-runs).
mkdir -p logs/slurm

# ── Provenance ──────────────────────────────────────────────────────
echo "JobID:    ${SLURM_JOB_ID:-n/a}"
echo "Node:     $(hostname)"
echo "GPU:      $(nvidia-smi --query-gpu=name --format=csv,noheader || true)"
echo "Commit:   $(git rev-parse HEAD 2>/dev/null || echo n/a)"
echo "Branch:   $(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo n/a)"
echo "Started:  $(date -Iseconds)"

# Pre-flight 1: assert the splits JSON has been regenerated with PDB-
# atom-sequence dedup (same gate as seed42_dedup).
python -c "
import json, sys
d = json.load(open('data/datasets/clustering/cluster_splits.json'))
n_members = d['params'].get('n_members', 0)
dedupe_by = d['params'].get('dedupe_by', None)
print(f'splits: n_members={n_members}, dedupe_by={dedupe_by!r}')
if dedupe_by is None or n_members > 300:
    print('ERROR: splits look like the pre-dedup (broken seed42) version.', file=sys.stderr)
    sys.exit(1)
if dedupe_by != 'pdb_atom_sequence':
    print(f'WARN: splits used --dedupe-by={dedupe_by!r}, not pdb_atom_sequence.', file=sys.stderr)
"

# Pre-flight 2: assert the LMDB was rebuilt under the new cap. We
# check by sampling a known previously-truncated GT (7zlg_K, was 113
# residues ending in WGQ) and verifying its heavy chain now extends
# past 113. If the LMDB still has the old truncation, abort — we
# don't want to burn 18h training on stale data.
python -c "
import sys
sys.path.insert(0, '.')
sys.path.insert(0, 'third_party/diffab')
import src.diffab_ft.datasets  # registers vhh_andd
from diffab.datasets import get_dataset
from diffab.utils.misc import load_config

cfg, _ = load_config('configs/diffab_ft/vhh_ft.yml')
ds_block = cfg.dataset.val
ds_block.split = 'test'
ds_block.transform = None
ds = get_dataset(ds_block)

probe = '7zlg_K'
if probe not in ds.ids_in_split:
    print(f'WARN: probe {probe} not in test split — skipping LMDB freshness check.', file=sys.stderr)
else:
    s = ds.get_structure(probe)
    n = len(s['heavy']['aa'])
    max_rs = int(s['heavy']['resseq'].max())
    print(f'LMDB probe {probe}: n_heavy={n}, max_resseq={max_rs}')
    if n <= 113 or max_rs <= 113:
        print(f'ERROR: LMDB looks stale (n={n}, max_resseq={max_rs}).', file=sys.stderr)
        print('Wipe + rebuild: rm data/processed/vhh_ft/structures.lmdb*', file=sys.stderr)
        sys.exit(1)
    print(f'LMDB looks fresh (J-anchor restored).')
"

# ── Run ─────────────────────────────────────────────────────────────
# W&B online mode so the live dashboard link prints in the first
# minute of the job (look for "View run at https://wandb.ai/..." in
# the log). If the compute node can't reach api.wandb.ai, W&B falls
# back to offline mode automatically and prints a sync command.
python scripts/diffab_ft/train.py \
    configs/diffab_ft/vhh_ft.yml \
    --output-dir runs/vhh_ft \
    --run-name   seed42_jfix \
    --num-workers 8 \
    --wandb-project vhh-diffab-ft \
    --wandb-run-name seed42_jfix \
    --wandb-group   vhh_ft \
    --wandb-mode    online

echo "Finished: $(date -Iseconds)"
